# Expo only inlines env vars prefixed with EXPO_PUBLIC_* into the client bundle.
# Anything without that prefix is stripped from device builds.

# Backend base URL — leave unset to run in dev-mode mocks (any username + code 000000)
# EXPO_PUBLIC_BACKEND_URL=https://app.beisser.cloud

# HTTP timeout in ms
# EXPO_PUBLIC_API_TIMEOUT=30000
