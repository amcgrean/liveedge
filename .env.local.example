# ──────────────────────────────────────────────────────────────
# Beisser Takeoff – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string from Neon (Vercel integration)
# Get this from: Vercel Dashboard → Storage → Your Neon DB → .env.local tab
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# NextAuth secret – generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# App URL (for NextAuth callbacks)
NEXTAUTH_URL="http://localhost:3000"

# Optional: Override default admin credentials for seeding
# ADMIN_EMAIL="admin@beisserlumber.com"
# ADMIN_PASSWORD="ChangeMe123!"
